// Bank Syariah Nasional — Sistem Tracking Penagihan
// Prisma schema · PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERVISOR
  PETUGAS
  ADMIN
}

// Cabang BSN (multi-tenant root). Tenancy is row-level: every scoped entity
// carries `branchId`. ADMIN role bypasses the scope; SUPERVISOR sees their
// own branch; PETUGAS sees only their own assignments inside that branch.
model Branch {
  id           String     @id @default(cuid())
  kode         String     @unique         // BSN001, BSN002, ...
  nama         String                     // "BSN Pusat", "BSN Cabang Depok", ...
  alamat       String?
  kepalaCabang String?
  active       Boolean    @default(true)
  // Branch-level monthly KPI targets — drive the Scorecard screen. Default
  // zero so a fresh cabang starts as "no target" rather than achieving 100%
  // by accident on a divide-by-zero.
  targetCollection   BigInt  @default(0)   // total tertagih (Rp) per bulan
  targetVisits       Int     @default(0)   // jumlah kunjungan per bulan
  targetApprovalRate Int     @default(85)  // approval rate % (0-100)
  // CV — monthly budget (Rp) per branch. Operational covers transport,
  // pulsa, etc; commission is the pot from which petugas komisi is paid.
  // Both default zero so untouched branches don't show fake utilization.
  budgetOperational  BigInt  @default(0)
  budgetCommission   BigInt  @default(0)
  users        User[]
  petugas      Petugas[]
  nasabah      Nasabah[]
  kunjungan    Kunjungan[]
  pembayaran   Pembayaran[]
  attendance   Attendance[]
  wilayah      Wilayah[]
  feedback     CustomerFeedback[]
  apiKeys      ApiKey[]
  webhooks     WebhookSubscription[]
  blast        Blast[]
  escalations  EscalationTicket[]
  transfersFrom PetugasTransfer[] @relation("TransferFrom")
  transfersTo   PetugasTransfer[] @relation("TransferTo")
  tags         Tag[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum PetugasStatus {
  LAPANGAN
  ISTIRAHAT
  KANTOR
}

enum KolKey {
  K1 // Lancar
  K2 // DPK
  K3 // Kurang Lancar
  K4 // Diragukan
  K5 // Macet
}

enum Akad {
  MURABAHAH
  MUSYARAKAH
  IJARAH
  MUSYARAKAH_MUTANAQISAH
  ISTISHNA
}

enum HasilKunjungan {
  BAYAR
  JANJI
  TIDAKADA
  TOLAK
}

enum BlastChannel {
  WA
  SMS
}

enum BlastStatus {
  TERJADWAL
  BERJALAN
  SELESAI
  GAGAL
  DIBATALKAN
}

model User {
  id                  String         @id @default(cuid())
  username            String         @unique
  passwordHash        String
  nama                String
  role                Role
  branch              Branch?        @relation(fields: [branchId], references: [id])
  branchId            String?        // null = HQ user (ADMIN scope); set for SUPERVISOR/PETUGAS
  petugas             Petugas?       @relation(fields: [petugasId], references: [id])
  petugasId           String?        @unique
  failedAttempts      Int            @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  // CU — presence: stamped each time the user hits /api/users/heartbeat
  // (the SPA fires one every 60s while focused). "Online now" lists pull
  // users whose lastSeenAt is within the last few minutes.
  lastSeenAt          DateTime?
  passwordChangedAt   DateTime       @default(now())
  mustChangePassword  Boolean        @default(false)
  active              Boolean        @default(true)
  // Optional email — populated for ADMIN users who receive the monthly
  // closing CSV. Other roles can leave it null.
  email               String?
  // TOTP 2FA. `totpSecret` stores AES-GCM ciphertext (IV + tag + ct hex-
  // concatenated) of the shared secret. `totpEnabledAt` is null while
  // setup is in flight; flipped to a timestamp on first successful
  // verification. ADMIN/SUPERVISOR strongly encouraged; PETUGAS optional.
  totpSecret          String?
  totpEnabledAt       DateTime?
  // Per-user notification preferences. Map of notification type → boolean.
  // Default (when null or key absent) is true so legacy users stay opted
  // in; new types added later default-on unless we override.
  notifPrefs          Json?
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  reviewedKunjungan   Kunjungan[]
  pushSubscriptions   PushSubscription[]
  createdApiKeys      ApiKey[]       @relation("ApiKeyCreator")
  savedFilters        SavedFilter[]
  createdWebhooks     WebhookSubscription[] @relation("WebhookCreator")
  createdCertifications PetugasCertification[] @relation("CertCreator")
  kunjunganEdits      KunjunganEditLog[]    @relation("EditLogEditor")
  escalationAssignments EscalationTicket[]  @relation("EscalationAssignee")
  leaveDecisions      PetugasLeave[]        @relation("LeaveApprover")
  transfersAuthored   PetugasTransfer[]     @relation("TransferMover")
  createdTags         Tag[]                 @relation("TagCreator")
  createdTagRules     TagRule[]             @relation("TagRuleCreator")
  authoredNasabahNotes NasabahNote[]        @relation("NasabahNoteAuthor")
  proposedRestructures NasabahRestructure[] @relation("RestructureProposer")
  decidedRestructures  NasabahRestructure[] @relation("RestructureDecider")
  uploadedNasabahDocuments NasabahDocument[] @relation("NasabahDocumentUploader")
  decidedAttendanceDisputes AttendanceDispute[] @relation("AttendanceDisputeDecider")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([branchId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // SHA-256 of the opaque token value — never store the plaintext.
  tokenHash String   @unique
  // Track rotation chain so reuse-detection can blow up a session lineage.
  parentId  String?
  family    String   // groups all tokens descended from one login
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([family])
}

enum NotifSeverity {
  INFO
  WARN
  CRIT
}

model Notification {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String        // "kunjungan.created", "blast.completed", ...
  title     String
  body      String?
  severity  NotifSeverity @default(INFO)
  link      String?       // optional in-app target (e.g. "tracking?petugas=P1")
  readAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, readAt, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?           // User.id (null untuk anonim: gagal login)
  actor     String?           // username snapshot
  action    String            // "auth.login.ok", "auth.login.fail", "nasabah.reassign", ...
  target    String?           // ID resource yang diaksi (nasabah ID, blast ID, dll)
  ip        String?
  userAgent String?
  meta      Json?             // payload tambahan (small)
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model Petugas {
  id        String        @id @default(cuid())
  kode      String        @unique          // P1, P2, ...
  nama      String
  inisial   String
  wilayah   String
  hp        String
  status    PetugasStatus @default(LAPANGAN)
  target    BigInt        @default(0)
  hue       Int           @default(156)
  // CD — commission rate as basis points (1 bps = 0.01%). Default 150 bps
  // = 1.5%. Stored as int to avoid float drift; UI renders as a decimal %.
  commissionBps Int       @default(150)
  // Soft delete — resigned petugas stay in the DB so their historical
  // kunjungan keep their FK. UI filters by default to active=true.
  active    Boolean       @default(true)
  branch    Branch        @relation(fields: [branchId], references: [id])
  branchId  String
  // Optional geofence — set when a wilayah polygon has been drawn for the
  // petugas. Anti-fraud uses it to flag laporan submitted outside the zone.
  wilayahZone   Wilayah? @relation(fields: [wilayahZoneId], references: [id])
  wilayahZoneId String?
  user      User?
  nasabah     Nasabah[]
  kunjungan   Kunjungan[]
  positions   PetugasPosition[]
  attendance  Attendance[]
  feedback    CustomerFeedback[]
  certifications PetugasCertification[]
  leaves      PetugasLeave[]
  substituteFor PetugasLeave[] @relation("LeaveSubstitute")
  transfers   PetugasTransfer[]
  attendanceDisputes AttendanceDispute[] @relation("AttendanceDisputePetugas")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([branchId])
  @@index([wilayahZoneId])
}

// Long-lived API key for machine-to-machine integration (partner systems,
// background reporting tools, etc). The plain token is shown ONCE at
// create; we only keep the SHA-256 hash so a DB dump alone can't be used
// to authenticate. tokenPrefix exists purely so the UI + audit log can
// identify a key by its leading 8 chars without revealing the whole thing.
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  // Hex SHA-256 of the raw token. Lookups use this column directly so the
  // raw token never round-trips through the DB after creation.
  tokenHash   String    @unique
  // First 12 chars of the raw token (e.g. "bsn_apikey_AbCd1234") so the
  // UI can show a readable identifier without revealing the secret tail.
  tokenPrefix String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdById String
  branch      Branch?   @relation(fields: [branchId], references: [id])
  branchId    String?
  // Coarse scope string ("read" or "write"). Future iterations can split
  // into per-resource scopes.
  scope       String    @default("read")
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([createdById])
  @@index([branchId])
  @@index([revokedAt])
}

// Per-user saved filter / preset view for the screens that have filter
// chrome (Laporan, Performa, Audit, etc). Persisted server-side so a
// supervisor can hop devices without losing their views.
model SavedFilter {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Free-form screen identifier — e.g. "laporan", "performa", "audit".
  screen    String
  name      String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, screen])
}

// Independent customer signal — nasabah dapat link tokenized via SMS
// pasca-kunjungan, isi rating 1-5 + komentar opsional. Petugas dengan
// rating rata-rata rendah konsisten ke-flag. Token random 64-char hex
// dipakai sebagai shareable URL, jadi tidak butuh nasabah login.
model CustomerFeedback {
  id          String    @id @default(cuid())
  token       String    @unique
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id])
  kunjunganId String    @unique
  nasabah     Nasabah   @relation(fields: [nasabahId], references: [id])
  nasabahId   String
  petugas     Petugas   @relation(fields: [petugasId], references: [id])
  petugasId   String
  branch      Branch    @relation(fields: [branchId], references: [id])
  branchId    String
  sentAt      DateTime  @default(now())
  rating      Int?      // 1..5; null sampai nasabah submit
  comment     String?
  repliedAt   DateTime?

  @@index([petugasId, repliedAt])
  @@index([branchId, sentAt])
}

// Geofence polygon per cabang. Drawn by supervisor on a map; vertex list
// stored as JSON (GeoJSON Polygon). Each Wilayah can be assigned to
// multiple petugas (e.g. shared coverage area). Soft delete preserves
// historical kunjungan that referenced the zone.
model Wilayah {
  id        String   @id @default(cuid())
  branch    Branch   @relation(fields: [branchId], references: [id])
  branchId  String
  nama      String
  // GeoJSON Polygon: { type: "Polygon", coordinates: [[[lng, lat], ...]] }
  // Stored as Json so Postgres jsonb gives us fast equality on the shape;
  // point-in-polygon happens in app code via turf.
  polygon   Json
  active    Boolean  @default(true)
  petugas   Petugas[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([active])
}

// Clock-in/out untuk hari ini. Satu petugas hanya boleh punya satu sesi
// terbuka (clockOutAt = null) pada waktu yang sama — enforced di route.
// Histori session lengkap diarsip untuk laporan absensi.
model Attendance {
  id           String   @id @default(cuid())
  petugas      Petugas  @relation(fields: [petugasId], references: [id])
  petugasId    String
  branch       Branch   @relation(fields: [branchId], references: [id])
  branchId     String
  clockInAt    DateTime @default(now())
  clockInLat   Float?
  clockInLng   Float?
  clockOutAt   DateTime?
  clockOutLat  Float?
  clockOutLng  Float?
  disputes     AttendanceDispute[]
  createdAt    DateTime @default(now())

  @@index([petugasId, clockInAt])
  @@index([branchId, clockInAt])
  @@index([petugasId, clockOutAt])
}

model PetugasPosition {
  id         String   @id @default(cuid())
  petugas    Petugas  @relation(fields: [petugasId], references: [id], onDelete: Cascade)
  petugasId  String
  lat        Float
  lng        Float
  accuracy   Float?
  recordedAt DateTime @default(now())

  @@index([petugasId, recordedAt])
}

model Nasabah {
  id         String      @id @default(cuid())
  kode       String      @unique           // N1000, N1001, ...
  nama       String
  alamat     String
  hp         String
  lat        Float?
  lng        Float?
  kol        KolKey      @default(K1)
  akad       Akad        @default(MURABAHAH)
  plafon     BigInt
  tenor      Int
  angsuran   BigInt
  sisa       BigInt
  dpd        Int         @default(0)
  dueIn      Int         @default(0)
  lastBayar  String?
  petugas    Petugas     @relation(fields: [petugasId], references: [id])
  petugasId  String
  branch     Branch      @relation(fields: [branchId], references: [id])
  branchId   String
  // Soft delete — pensiun / lunas / wanprestasi-final masuk inactive
  // tapi histori kunjungan + pembayaran tetap terjaga.
  active     Boolean     @default(true)
  // Next-visit scheduler. Set automatically by the cadence rule on every
  // kunjungan.create (based on kol + hasil), or overridden manually by
  // SUPERVISOR/ADMIN via PATCH /:id/next-visit. Null = no plan yet.
  nextVisitAt DateTime?
  // DK — fraud / wanprestasi flag. blacklistedAt is set on toggle so we
  // know when it happened; clearing the flag clears all three. Bulk
  // import refuses to recreate a blacklisted kode.
  blacklisted     Boolean   @default(false)
  blacklistReason String?
  blacklistedAt   DateTime?
  kunjungan      Kunjungan[]
  pembayaran     Pembayaran[]
  blastRecipient BlastRecipient[]
  feedback       CustomerFeedback[]
  escalations    EscalationTicket[]
  tags           NasabahTag[]
  notes          NasabahNote[]
  restructures   NasabahRestructure[]
  documents      NasabahDocument[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([petugasId])
  @@index([kol])
  @@index([branchId])
  @@index([active])
  @@index([blacklisted])
}

model Kunjungan {
  id         String         @id @default(cuid())
  petugas    Petugas        @relation(fields: [petugasId], references: [id])
  petugasId  String
  nasabah    Nasabah        @relation(fields: [nasabahId], references: [id])
  nasabahId  String
  branch     Branch         @relation(fields: [branchId], references: [id])
  branchId   String
  hasil      HasilKunjungan
  nominal    BigInt         @default(0)
  catatan    String
  lokasi     String
  lat        Float?
  lng        Float?
  valid      Boolean        @default(true)
  // Anti-fraud surface. riskFlags lists detected anomalies (e.g. "gps_far",
  // "photo_stale", "no_exif_date"); riskScore is the summed severity. A
  // non-zero score flips `valid` to false at write time and surfaces a
  // "perlu review" badge on the supervisor's report list.
  riskScore  Int            @default(0)
  riskFlags  String[]       @default([])
  // Review pipeline. Laporan dengan riskScore > 0 mulai dari PENDING; yang
  // bersih auto-APPROVED. Supervisor bisa Setujui / Tolak dengan catatan.
  reviewStatus ReviewStatus @default(APPROVED)
  reviewerId   String?
  reviewer     User?        @relation(fields: [reviewerId], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  // SLA monitor — set the first time the alert worker has notified the
  // branch supervisors that this PENDING row has gone past the SLA
  // threshold, so we don't double-page them every poll cycle.
  slaAlertedAt DateTime?
  fotos      Foto[]
  feedback     CustomerFeedback?
  editLogs   KunjunganEditLog[]
  jam        String
  tanggal    DateTime       @default(now())   // the visit time (can be backdated)
  createdAt  DateTime       @default(now())   // the insertion time; gates edit/delete window
  // BY — archive worker stamps this when an APPROVED/REJECTED kunjungan is
  // older than ARCHIVE_AFTER_DAYS. Archived rows still exist (analytics +
  // GDPR exports keep working) but the default list filters them out.
  archivedAt DateTime?

  @@index([petugasId, tanggal])
  @@index([nasabahId, tanggal])
  @@index([branchId, tanggal])
  @@index([reviewStatus])
  @@index([archivedAt])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// Web Push subscription per user/browser. One user can have multiple
// devices, so we de-dupe on endpoint (unique across users).
model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  authKey   String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Foto {
  id          String    @id @default(cuid())
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)
  kunjunganId String
  path        String
  // Supervisor annotations stored as a JSON array of shapes (arrow / circle /
  // rect / note) with normalized 0..1 coordinates so they render correctly
  // at any display size. Lihat `web/src/components/PhotoAnnotator.tsx` untuk
  // skema lengkap.
  annotations Json      @default("[]")
  createdAt   DateTime  @default(now())
}

// Webhook subscriptions for external integrations. Each subscription holds
// an HMAC secret used to sign deliveries with X-BSN-Signature so the
// receiver can verify the payload originated here. Delivery attempts are
// logged separately (WebhookDelivery) with retry status so operators can
// audit failures.
model WebhookSubscription {
  id           String   @id @default(cuid())
  name         String
  url          String
  // HMAC-SHA256 secret; presented once at create then masked in lists.
  secret       String
  // Array of event topics this subscription wants — "kunjungan.created",
  // "kunjungan.reviewed", etc. Empty array = subscribe to all topics.
  events       String[]
  branch       Branch?  @relation(fields: [branchId], references: [id])
  branchId     String?
  active       Boolean  @default(true)
  createdBy    User     @relation("WebhookCreator", fields: [createdById], references: [id])
  createdById  String
  lastDeliveryAt DateTime?
  createdAt    DateTime @default(now())
  deliveries   WebhookDelivery[]

  @@index([active])
  @@index([branchId])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhook         WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  webhookId       String
  event           String
  payload         Json
  status          String   // 'success' | 'pending' | 'failed' | 'dead_letter'
  responseStatus  Int?     // HTTP status from receiver
  attempts        Int      @default(0)
  error           String?
  // Retry scheduler — `pending` rows are picked up by the dispatcher when
  // nextAttemptAt has passed. `dead_letter` rows have exhausted retries
  // and stay dormant unless an operator hits /retry manually.
  nextAttemptAt   DateTime?
  lastAttemptAt   DateTime?
  createdAt       DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([status, createdAt])
  @@index([status, nextAttemptAt])
}

model Pembayaran {
  id        String   @id @default(cuid())
  nasabah   Nasabah  @relation(fields: [nasabahId], references: [id])
  nasabahId String
  branch    Branch   @relation(fields: [branchId], references: [id])
  branchId  String
  nominal   BigInt
  metode    String   // tunai | transfer | autodebet
  status    String   @default("berhasil")
  jam       String
  tanggal   DateTime @default(now())

  @@index([nasabahId, tanggal])
  @@index([branchId, tanggal])
}

model Blast {
  id           String       @id @default(cuid())
  judul        String
  kanal        BlastChannel
  template     String
  status       BlastStatus  @default(TERJADWAL)
  target       Int          @default(0)
  terkirim     Int          @default(0)
  dibaca       Int?
  scheduledAt  DateTime?
  branch       Branch       @relation(fields: [branchId], references: [id])
  branchId     String
  createdAt    DateTime     @default(now())
  recipients   BlastRecipient[]

  @@index([branchId, createdAt])
}

model BlastRecipient {
  id        String  @id @default(cuid())
  blast     Blast   @relation(fields: [blastId], references: [id], onDelete: Cascade)
  blastId   String
  nasabah   Nasabah @relation(fields: [nasabahId], references: [id])
  nasabahId String
  hp        String
  status    String  @default("pending")  // pending | terkirim | gagal | dibaca
  sentAt    DateTime?

  @@unique([blastId, nasabahId])
}

// AV — petugas certification / kompetensi tracker. Each row is one cert
// (e.g. AAJI, OJK collector cert). issuedAt is when it was earned;
// validUntil tags expiry. UI sorts by validUntil so things about to lapse
// surface first; a worker (or just supervisor review) handles renewal.
model PetugasCertification {
  id            String    @id @default(cuid())
  petugas       Petugas   @relation(fields: [petugasId], references: [id], onDelete: Cascade)
  petugasId     String
  nama          String
  penerbit      String?
  noSertifikat  String?
  issuedAt      DateTime
  validUntil    DateTime?
  status        String    @default("aktif")  // aktif | dicabut | expired
  catatan       String?
  createdById   String?
  createdBy     User?     @relation("CertCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([petugasId, validUntil])
}

// BT — log per-edit on a kunjungan. Each PATCH creates one row so the
// audit viewer can render a side-by-side timeline of what changed.
model KunjunganEditLog {
  id           String    @id @default(cuid())
  kunjungan    Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)
  kunjunganId  String
  editor       User      @relation("EditLogEditor", fields: [editorId], references: [id])
  editorId     String
  // Changed fields as JSON: { field: { from, to } }
  changes      Json
  createdAt    DateTime  @default(now())

  @@index([kunjunganId, createdAt])
}

// CK — escalation ticket. Worker creates one per (nasabah × open ticket)
// when a high-kol customer goes too long without successful payment.
// Supervisors close them once contact has been made or another action
// taken; closed tickets stay in the table as the paper trail.
model EscalationTicket {
  id         String    @id @default(cuid())
  nasabah    Nasabah   @relation(fields: [nasabahId], references: [id])
  nasabahId  String
  branch     Branch    @relation(fields: [branchId], references: [id])
  branchId   String
  // 'critical' (kol K5 or DPD > 90), 'high' (K4), 'medium' (K3 + no payment ≥ 30d)
  severity   String
  reason     String    // human-readable: "K5 — 45 hari tanpa bayar"
  // 'open' (auto-created) → 'in_progress' (supervisor acknowledged)
  // → 'resolved' (action taken) | 'dismissed' (false positive)
  status     String    @default("open")
  note       String?
  assignedTo User?     @relation("EscalationAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([branchId, status, createdAt])
  @@index([nasabahId, status])
}

// CS — petugas leave/cuti record. SUPERVISOR creates and approves; the
// morning-reminder + inactivity workers consult `approved` rows to skip a
// petugas on the dates they're out. Soft delete via status='cancelled' so
// withdrawn requests stay in the trail.
model PetugasLeave {
  id          String    @id @default(cuid())
  petugas     Petugas   @relation(fields: [petugasId], references: [id], onDelete: Cascade)
  petugasId   String
  startDate   DateTime
  endDate     DateTime
  type        String    // 'cuti_tahunan' | 'sakit' | 'dinas_luar' | 'lain'
  status      String    @default("pending")    // pending | approved | rejected | cancelled
  reason      String?
  approvedBy  User?     @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvedById String?
  decisionAt  DateTime?
  // DG — optional substitute. Worker swaps all nasabah of `petugasId`
  // over to `substitutePetugasId` on the leave's start date, then
  // restores them when the leave ends. Both transitions are audited.
  substitutePetugas   Petugas?  @relation("LeaveSubstitute", fields: [substitutePetugasId], references: [id])
  substitutePetugasId String?
  // True after the start-of-leave swap has fired; flipped back to false
  // after restoration so the worker stays idempotent.
  reassigned          Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([petugasId, status, startDate])
  @@index([status, endDate])
}

// CC — petugas branch-transfer history. One row per move; the worker
// inside routes/petugas.PATCH writes it when branchId changes. Closed
// transfers stay in the table as audit context.
model PetugasTransfer {
  id          String   @id @default(cuid())
  petugas     Petugas  @relation(fields: [petugasId], references: [id], onDelete: Cascade)
  petugasId   String
  fromBranch  Branch   @relation("TransferFrom", fields: [fromBranchId], references: [id])
  fromBranchId String
  toBranch    Branch   @relation("TransferTo", fields: [toBranchId], references: [id])
  toBranchId  String
  reason      String?
  movedBy     User?    @relation("TransferMover", fields: [movedById], references: [id])
  movedById   String?
  createdAt   DateTime @default(now())

  @@index([petugasId, createdAt])
  @@index([fromBranchId, createdAt])
  @@index([toBranchId, createdAt])
}

// CX — nasabah segmentation labels. Tags are branch-scoped (or HQ-global
// when branchId is null) and many-to-many on Nasabah via NasabahTag.
// SUPERVISOR creates within their branch; ADMIN may create global tags.
model Tag {
  id          String       @id @default(cuid())
  name        String
  color       String       @default("#64748b")   // tailwind slate-500 — neutral default
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId    String?
  createdBy   User?        @relation("TagCreator", fields: [createdById], references: [id])
  createdById String?
  nasabah     NasabahTag[]
  rules       TagRule[]    @relation("TagRuleTag")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([branchId, name])
  @@index([branchId])
}

model NasabahTag {
  nasabah     Nasabah  @relation(fields: [nasabahId], references: [id], onDelete: Cascade)
  nasabahId   String
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId       String
  // DH — when set, this NasabahTag was applied automatically by a rule
  // sweep rather than a human assigner. Auto-applied rows can be removed
  // by the sweep when the rule no longer matches; manual rows are kept.
  ruleId      String?
  createdAt   DateTime @default(now())

  @@id([nasabahId, tagId])
  @@index([tagId])
  @@index([ruleId])
}

// DH — auto-tagging rules. Each rule maps a condition over the nasabah
// state to a single tag. The daily sweep applies the tag to matching
// nasabah (idempotent) and removes auto-applied tags when the condition
// no longer holds. Manual assignments (ruleId null) are never touched.
enum TagRuleType {
  DPD_ABOVE
  DAYS_SINCE_PAYMENT_ABOVE
  KOL_IN
}

model TagRule {
  id            String       @id @default(cuid())
  tag           Tag          @relation("TagRuleTag", fields: [tagId], references: [id], onDelete: Cascade)
  tagId         String
  name          String
  type          TagRuleType
  threshold     Int?         // for DPD_ABOVE + DAYS_SINCE_PAYMENT_ABOVE
  kolValues     String[]     @default([])     // for KOL_IN — list of KolKey enum values
  active        Boolean      @default(true)
  createdBy     User?        @relation("TagRuleCreator", fields: [createdById], references: [id])
  createdById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tagId])
  @@index([active])
}

// DI — internal notes timeline on a nasabah, separate from kunjungan +
// feedback. SUPERVISOR/PETUGAS/ADMIN can read/create; author or ADMIN
// can delete.
model NasabahNote {
  id        String   @id @default(cuid())
  nasabah   Nasabah  @relation(fields: [nasabahId], references: [id], onDelete: Cascade)
  nasabahId String
  author    User     @relation("NasabahNoteAuthor", fields: [authorId], references: [id])
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([nasabahId, createdAt])
}

// DN — nasabah document attachments (KTP, kontrak, foto agunan, etc).
// File lives on disk via the same /uploads mount as kunjungan photos.
// `path` is relative to the project root.
enum NasabahDocumentKind {
  KTP
  KONTRAK
  AGUNAN
  SLIP_GAJI
  LAIN
}

model NasabahDocument {
  id          String              @id @default(cuid())
  nasabah     Nasabah             @relation(fields: [nasabahId], references: [id], onDelete: Cascade)
  nasabahId   String
  kind        NasabahDocumentKind
  fileName    String
  filePath    String
  mimeType    String
  sizeBytes   Int
  notes       String?
  uploadedBy  User?               @relation("NasabahDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt   DateTime            @default(now())

  @@index([nasabahId, createdAt])
}

// DO — attendance dispute. Petugas requests a correction (e.g. forgot
// to clock out) on one of their own Attendance rows. SUPERVISOR/ADMIN
// approves to apply the suggested clockIn / clockOut times atomically.
enum AttendanceDisputeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model AttendanceDispute {
  id              String                  @id @default(cuid())
  attendance      Attendance              @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  attendanceId    String
  petugas         Petugas                 @relation("AttendanceDisputePetugas", fields: [petugasId], references: [id])
  petugasId       String
  status          AttendanceDisputeStatus @default(PENDING)
  reason          String
  proposedClockIn  DateTime?
  proposedClockOut DateTime?
  decidedBy       User?                   @relation("AttendanceDisputeDecider", fields: [decidedById], references: [id])
  decidedById     String?
  decisionNote    String?
  decidedAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([attendanceId])
  @@index([status])
  @@index([petugasId, createdAt])
}

// DL — restructure / pelunasan dipercepat proposal. Petugas/Supervisor
// drafts new sisa/angsuran/tenor; supervisor (or admin) approves to
// flip Nasabah's plan. Old values stored so audit trail is preserved
// even if Nasabah was later edited.
enum RestructureStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model NasabahRestructure {
  id            String            @id @default(cuid())
  nasabah       Nasabah           @relation(fields: [nasabahId], references: [id], onDelete: Cascade)
  nasabahId     String
  status        RestructureStatus @default(PENDING)
  reason        String
  oldSisa       BigInt
  newSisa       BigInt
  oldAngsuran   BigInt
  newAngsuran   BigInt
  oldTenor      Int
  newTenor      Int
  proposedBy    User              @relation("RestructureProposer", fields: [proposedById], references: [id])
  proposedById  String
  decidedBy     User?             @relation("RestructureDecider", fields: [decidedById], references: [id])
  decidedById   String?
  decisionNote  String?
  decidedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([nasabahId, createdAt])
  @@index([status])
}
