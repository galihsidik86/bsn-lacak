# BSN Lacak — root .env for docker compose
# Copy to .env and fill in real values before `docker compose up`.

# ---- Database ----
POSTGRES_DB=bsn_lacak
POSTGRES_USER=bsn
POSTGRES_PASSWORD=ganti-password-postgres-yang-kuat

# ---- API ----
# JWT secret — generate a strong one:  openssl rand -base64 48
JWT_SECRET=ganti-dengan-secret-acak-min-32-karakter
JWT_EXPIRES_IN=15m
REFRESH_TTL_DAYS=7

# Origin of the web client (nginx public URL). Set to your domain.
WEB_ORIGIN=https://lacak.bsn.local

# Cookie flags — secure=true requires HTTPS (set true once cert is in place).
COOKIE_SECURE=true
# COOKIE_DOMAIN=.bsn.co.id

# ---- Web build ----
# Public base URL the SPA calls. With this compose, nginx serves both on the
# same origin, so /api works. Override only if the API is on a separate host.
PUBLIC_API_URL=/api

# Google Maps JS API key (leave empty to fall back to the stylized map)
VITE_GOOGLE_MAPS_API_KEY=

# ---- Backup ----
BACKUP_RETENTION_DAYS=7

# ---- Blast gateway ----
# stub | twilio
BLAST_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=+1XXXXXXXXXX
TWILIO_WA_FROM=whatsapp:+1XXXXXXXXXX
