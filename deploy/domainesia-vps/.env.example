# BSN Lacak — .env minimal untuk Domainesia VPS (slim demo).
#
# Copy ke .env di folder yang sama, lalu generate value asli:
#   openssl rand -base64 24    # untuk POSTGRES_PASSWORD
#   openssl rand -base64 48    # untuk JWT_SECRET
#
# Compose di-launch dengan:
#   docker compose -f docker-compose.slim.yml --env-file .env up -d --build

# ---- Database ----
POSTGRES_DB=bsn_lacak
POSTGRES_USER=bsn
POSTGRES_PASSWORD=ganti-dengan-openssl-rand-base64-24

# ---- API ----
JWT_SECRET=ganti-dengan-openssl-rand-base64-48
JWT_EXPIRES_IN=15m
REFRESH_TTL_DAYS=7

# Domain demo. Cookie secure WAJIB true karena lewat HTTPS (Caddy).
WEB_ORIGIN=https://lacak.sosmartpro.com
COOKIE_SECURE=true
# Aktifkan kalau API & web nantinya beda subdomain (tidak perlu untuk single
# subdomain di Caddy block default).
# COOKIE_DOMAIN=.sosmartpro.com

# ---- Blast gateway ----
# stub = log saja, tidak mengirim ke provider. Untuk demo: tetap stub.
BLAST_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_WA_FROM=
