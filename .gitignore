# ---- Secrets — never commit ----
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ---- Node ----
node_modules/
**/node_modules/

# ---- Build artifacts ----
dist/
**/dist/
*.tsbuildinfo

# ---- Logs ----
*.log
**/*.log
logs/

# ---- Runtime data ----
api/uploads/
api/audit-archive/

# ---- Test output ----
coverage/
test-results/
playwright-report/
playwright/.cache/

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ---- Claude Code workspace ----
.claude/

# ---- Vite / PWA cache ----
.vite/
**/.vite/

# ---- Prisma generated client (regenerated by `prisma generate`) ----
api/node_modules/@prisma/client
